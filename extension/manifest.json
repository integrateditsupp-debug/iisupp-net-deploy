{
  "manifest_version": 3,
  "name": "ARIA by Integrated IT Support",
  "version": "1.0.0",
  "description": "ARIA follows your browsing with intelligent, privacy-aware support — reminders, search, trading news, tech triage.",
  "permissions": ["storage", "notifications", "alarms", "activeTab", "scripting"],
  "host_permissions": ["https://iisupport.net/*", "https://*.iisupport.net/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ARIA Assistant"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/i-16.png",
    "32": "icons/i-32.png",
    "128": "icons/i-128.png"
  }
}
